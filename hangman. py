import random

def play_hangman():
    # 1. Predefined list of 5 words
    words = ["python", "coding", "program", "intern", "laptop"]
    
    # Randomly select a word from the list
    secret_word = random.choice(words)
    
    # Create a list of underscores to represent the hidden letters
    guessed_word = ["_"] * len(secret_word)
    
    # Track incorrect guesses left (Limit set to 6)
    attempts_left = 6
    
    # Keep track of letters already guessed by the player
    guessed_letters = []

    print("--- Welcome to Horizon TechX Hangman Game! ---")
    print(f"The secret word has {len(secret_word)} letters.")

    # 2. Main game loop using a while loop
    while attempts_left > 0 and "_" in guessed_word:
        print("\nWord to guess: " + " ".join(guessed_word))
        print(f"Attempts left: {attempts_left}")
        print(f"Guessed letters: {', '.join(guessed_letters) if guessed_letters else 'None'}")
        
        # Take user input
        guess = input("Guess a letter: ").lower().strip()

        # Input validation
        if len(guess) != 1 or not guess.isalpha():
            print("Invalid input! Please enter a single alphabetical letter.")
            continue
        
        if guess in guessed_letters:
            print("You already guessed that letter. Try a different one!")
            continue

        # Add guess to the tracked list
        guessed_letters.append(guess)

        # 3. Check if the guess is in the secret word (if-else logic)
        if guess in secret_word:
            print(f"Good job! '{guess}' is in the word.")
            # Update the hidden word display
            for index, letter in enumerate(secret_word):
                if letter == guess:
                    guessed_word[index] = guess
        else:
            print(f"Sorry, '{guess}' is not in the word.")
            attempts_left -= 1  # Reduce a life for incorrect guess

    # 4. Game Over conditions
    print("\n-----------------------------------")
    if "_" not in guessed_word:
        print(f"Congratulations! You won! The word was: {secret_word}")
    else:
        print(f"Game Over! You ran out of attempts. The word was: {secret_word}")
    print("-----------------------------------")

# Run the game
if __name__ == "__main__":
    play_hangman()
